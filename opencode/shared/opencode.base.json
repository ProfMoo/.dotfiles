{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "skill": "allow",
    "task": "allow",
    "edit": "ask",
    "webfetch": "allow",
    "bash": {
      "*": "ask",
      "tail *": "allow",
      "head *": "allow",
      "grep *": "allow",
      "echo *": "allow",
      "make *": "allow",
      "pwd": "allow",
      "ls *": "allow",
      "sort *": "allow",
      "find *": "allow",
      "xargs *": "allow",
      "cd *": "allow",
      "mkdir *": "allow",
      "awk *": "allow",
      "cat *": "allow",
      "wc *": "allow",
      "go *": "allow",
      "gosimports *": "allow",
      "gofumpt *": "allow",
      "npx *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git diff *": "allow",
      "git status *": "allow",
      "git add *": "allow",
      "git remote -v": "allow",
      "git checkout *": "allow",
      "git branch --show-current": "allow",
      "osascript": "deny",
      "osascript *": "deny",
      "*/osascript": "deny",
      "*/osascript *": "deny"
    }
  },
  "share": "disabled",
  "autoupdate": false,
  "experimental": {
    "openTelemetry": true
  }
}
